# Copy to .env and fill in values.

# Gemini / CrewAI
GOOGLE_API_KEY=
CREWAI_MODEL=gemini/gemini-2.5-flash

# SQLite (optional override)
# DATABASE_URL=sqlite:///C:/path/to/app.db

# Google OAuth (Calendar) — create OAuth client (Web) in Google Cloud Console
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Must match an authorized redirect URI (e.g. ngrok or localhost)
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/integrations/google/callback
